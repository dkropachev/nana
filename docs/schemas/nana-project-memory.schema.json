{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dkropachev.github.io/nana/schemas/nana-project-memory.schema.json",
  "title": "NANA project memory",
  "description": "Durable, extension-friendly project memory stored at .nana/project-memory.json. An empty object is valid.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "repo": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memoryEntry"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memoryEntry"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memoryEntry"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memoryEntry"
      }
    },
    "preferences": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memoryEntry"
      }
    }
  },
  "$defs": {
    "memoryEntry": {
      "description": "Memory entries may be simple text or structured records with repo-specific metadata.",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "id": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "value": {
              "type": "string"
            },
            "created_at": {
              "type": "string",
              "format": "date-time"
            },
            "updated_at": {
              "type": "string",
              "format": "date-time"
            },
            "source": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
