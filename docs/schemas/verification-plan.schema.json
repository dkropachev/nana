{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dkropachev.github.io/nana/schemas/verification-plan.schema.json",
  "title": "NANA managed verification plan",
  "description": "Managed repository verification plan consumed by `nana verify` from verification-plan.json in Nana-managed repo state.",
  "type": "object",
  "additionalProperties": false,
  "required": ["stages"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "lint": {
      "type": "array",
      "items": { "type": "string" }
    },
    "compile": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unit": {
      "type": "array",
      "items": { "type": "string" }
    },
    "integration": {
      "type": "array",
      "items": { "type": "string" }
    },
    "benchmarks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plan_fingerprint": {
      "type": "string"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "checksum", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "checksum": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "kind": { "type": "string", "minLength": 1, "pattern": "\\S" }
        }
      }
    },
    "changed_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_check"],
      "properties": {
        "description": {
          "type": "string"
        },
        "full_check": {
          "type": "object",
          "additionalProperties": false,
          "required": ["command"],
          "properties": {
            "description": {
              "type": "string"
            },
            "command": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            }
          }
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "patterns"],
            "anyOf": [
              {
                "required": ["stages"],
                "properties": {
                  "stages": {
                    "type": "array",
                    "contains": {
                      "type": "string",
                      "pattern": "\\S"
                    },
                    "minContains": 1
                  }
                }
              },
              {
                "required": ["checks"],
                "properties": {
                  "checks": {
                    "type": "array",
                    "contains": {
                      "type": "string",
                      "pattern": "\\S"
                    },
                    "minContains": 1
                  }
                }
              }
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "pattern": "\\S"
              },
              "description": {
                "type": "string"
              },
              "patterns": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                },
                "contains": {
                  "type": "string",
                  "pattern": "\\S"
                },
                "minContains": 1
              },
              "stages": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "checks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "description": {
            "type": "string"
          },
          "command": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    }
  }
}
